@using Microsoft.AspNetCore.Components.Routing

<Router AppAssembly="@typeof(MainWindow).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(BackupCR.Components.MainLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <LayoutView Layout="@typeof(BackupCR.Components.MainLayout)">
            <div class="content-wrapper">
                <div class="table-container" style="padding: 40px; text-align: center;">
                    <svg class="nav-icon" style="width: 48px; height: 48px; color: var(--text-muted); margin-bottom: 16px;" viewBox="0 0 24 24">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" fill="currentColor"/>
                    </svg>
                    <h2 style="margin-bottom: 8px;">Página Não Encontrada</h2>
                    <p style="color: var(--text-secondary);">O endereço solicitado não foi localizado neste agente.</p>
                </div>
            </div>
        </LayoutView>
    </NotFound>
</Router>
