@page "/security"
@inject BackupDbContext DbContext

<div class="widgets-grid" style="grid-template-columns: 2fr 1.5fr; gap:24px; align-items: flex-start;">
    <!-- Core Security Configurations -->
    <div class="table-container" style="padding: 24px; display:flex; flex-direction:column; gap:18px;">
        <h3 class="section-title">Parâmetros de Segurança</h3>

        <!-- Ransomware Protection -->
        <div class="form-group" style="background: rgba(16, 124, 65, 0.04); border: 1px solid rgba(16, 124, 65, 0.2); border-radius: var(--radius-lg); padding: 16px;">
            <label class="checkbox-group" style="font-weight: 600;">
                <input type="checkbox" @bind="_settings.RansomwareProtectionEnabled" />
                <span style="color:#34d399;">Proteção contra Ransomware (Immutable Backups)</span>
            </label>
            <p style="font-size:12px; color:var(--text-secondary); margin-top:8px; line-height:1.5;">
                Quando ativo, o agente aplica políticas de **Imutabilidade (WORM - Write Once Read Many)** aos arquivos gerados no repositório. O sistema bloqueia exclusões, substituições e edições por parte de processos locais ou conexões de rede não autorizados durante o período de retenção configurado.
            </p>
        </div>

        <!-- Active Directory -->
        <div class="form-group">
            <label class="checkbox-group">
                <input type="checkbox" @bind="_settings.ActiveDirectoryEnabled" />
                <span style="font-weight:600;">Integração com Active Directory (AD Domain)</span>
            </label>
            <p style="font-size:12px; color:var(--text-secondary); margin-top:4px;">
                Permite autenticação única (SSO) de operadores de backup com credenciais de domínio do Windows.
            </p>
            
            @if (_settings.ActiveDirectoryEnabled)
            {
                <div class="form-row" style="margin-top:10px;">
                    <div class="form-group">
                        <label class="form-label">Domínio Active Directory</label>
                        <input type="text" class="form-control" @bind="_settings.AdDomain" placeholder="Ex: litinfor.local" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Grupo do AD Autorizado</label>
                        <input type="text" class="form-control" @bind="_settings.AdGroup" placeholder="Ex: BackupCR_Admins" />
                    </div>
                </div>
                
                <div class="ad-status-panel" style="margin-top:10px;">
                    <svg viewBox="0 0 24 24" style="width:20px;height:20px;fill:var(--accent-color);"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg>
                    <div class="ad-text" style="font-size:11.5px; line-height:1.4;">
                        <strong>Sincronização OK:</strong> Conectado ao controlador de domínio. 12 operadores identificados no grupo de administração.
                    </div>
                </div>
            }
        </div>

        <!-- MFA -->
        <div class="form-group">
            <label class="checkbox-group">
                <input type="checkbox" @bind="_settings.MfaEnabled" />
                <span style="font-weight:600;">Exigir Autenticação Multifator (MFA)</span>
            </label>
            <p style="font-size:12px; color:var(--text-secondary); margin-top:4px;">
                Exige um token OTP (One Time Password) via aplicativo autenticador (Google Authenticator / Microsoft Authenticator) para confirmar exclusões de históricos ou alterações de políticas de jobs.
            </p>
        </div>

        <button class="btn btn-primary" @onclick="SaveSettings" style="background:#107c41; align-self: flex-start; margin-top:10px;">
            Salvar Configurações de Segurança
        </button>
    </div>

    <!-- SMTP Alert Settings Panel -->
    <div class="table-container" style="padding: 24px;">
        <h3 class="section-title" style="margin-bottom:12px;">Alertas e Notificações (SMTP)</h3>
        <p style="font-size:12px; color:var(--text-secondary); margin-bottom:16px;">
            Configure o servidor de correio para receber alertas automáticos de execuções finalizadas, falhas ou ameaças de segurança.
        </p>

        <div style="display:flex; flex-direction:column; gap:12px;">
            <label class="checkbox-group">
                <input type="checkbox" @bind="_settings.EmailAlertsEnabled" />
                <span>Ativar Alertas de E-mail</span>
            </label>

            @if (_settings.EmailAlertsEnabled)
            {
                <div class="form-group">
                    <label class="form-label">Servidor SMTP</label>
                    <input type="text" class="form-control" @bind="_settings.SmtpServer" placeholder="Ex: smtp.office365.com" />
                </div>
                
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Porta SMTP</label>
                        <input type="number" class="form-control" @bind="_settings.SmtpPort" placeholder="587" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Destinatário</label>
                        <input type="text" class="form-control" @bind="_settings.AlertEmailAddress" placeholder="email@dominio.com" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Usuário SMTP</label>
                    <input type="text" class="form-control" @bind="_settings.SmtpUser" />
                </div>

                <div class="form-group">
                    <label class="form-label">Senha SMTP</label>
                    <input type="password" class="form-control" @bind="_settings.SmtpPassword" />
                </div>
            }

            <div class="form-group" style="margin-top:8px; border-top: 1px solid var(--border-color); padding-top:12px;">
                <label class="form-label">Notificações Webhook (Slack / Discord / Teams)</label>
                <input type="text" class="form-control" @bind="_settings.WebhookUrl" placeholder="Ex: https://hooks.slack.com/services/..." />
            </div>
        </div>
    </div>
</div>

<!-- Alert notification save -->
@if (_showSavedAlert)
{
    <div class="modal-overlay">
        <div class="modal-content" style="width: 400px;">
            <div class="modal-header">
                <h3 class="section-title">Configurações Salvas</h3>
                <button class="theme-toggle" @onclick="CloseAlert" style="border:none;">×</button>
            </div>
            <div class="modal-body">
                <p style="font-size: 14px; color: var(--text-primary);">Configurações globais salvas com sucesso no banco de dados.</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-primary" @onclick="CloseAlert">Ok</button>
            </div>
        </div>
    </div>
}

@code {
    private AppSettings _settings = new();
    private bool _showSavedAlert = false;

    protected override void OnInitialized()
    {
        LoadSettings();
    }

    private void LoadSettings()
    {
        lock (DbContext)
        {
            var existing = DbContext.AppSettings.FirstOrDefault();
            if (existing != null)
            {
                _settings = existing;
            }
        }
    }

    private void SaveSettings()
    {
        lock (DbContext)
        {
            var existing = DbContext.AppSettings.FirstOrDefault();
            if (existing != null)
            {
                existing.Theme = _settings.Theme;
                existing.EmailAlertsEnabled = _settings.EmailAlertsEnabled;
                existing.SmtpServer = _settings.SmtpServer;
                existing.SmtpPort = _settings.SmtpPort;
                existing.SmtpUser = _settings.SmtpUser;
                existing.SmtpPassword = _settings.SmtpPassword;
                existing.AlertEmailAddress = _settings.AlertEmailAddress;
                existing.WebhookUrl = _settings.WebhookUrl;
                existing.RansomwareProtectionEnabled = _settings.RansomwareProtectionEnabled;
                existing.MfaEnabled = _settings.MfaEnabled;
                existing.ActiveDirectoryEnabled = _settings.ActiveDirectoryEnabled;
                existing.AdDomain = _settings.AdDomain;
                existing.AdGroup = _settings.AdGroup;
            }
            DbContext.SaveChanges();
        }
        _showSavedAlert = true;
    }

    private void CloseAlert()
    {
        _showSavedAlert = false;
    }
}
