@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationService NavigationService
@inject NavigationManager NavigationManager
@inject BackupDbContext DbContext

<div class="app-container" data-theme="@_theme">
    <!-- Sidebar Navigation -->
    <aside class="sidebar">
        <div class="brand">
            <!-- Veeam inspired visual logo -->
            <svg class="brand-icon" viewBox="0 0 36 36" fill="none">
                <rect width="36" height="36" rx="8" fill="#107C41"/>
                <path d="M8 20V26H28V20H8Z" fill="white"/>
                <path d="M8 10V17H15V10H8Z" fill="white"/>
                <path d="M21 10V17H28V10H21Z" fill="white"/>
                <path d="M11 13H12V14H11V13Z" fill="#107C41"/>
                <path d="M24 13H25V14H24V13Z" fill="#107C41"/>
            </svg>
            <span class="brand-name">BackupCR</span>
        </div>

        <ul class="nav-menu">
            <li class="nav-item @GetActiveCss("")">
                <a href="" @onclick='() => NavigateTo("")'>
                    <svg class="nav-icon" viewBox="0 0 24 24">
                        <path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z" />
                    </svg>
                    Dashboard
                </a>
            </li>
            <li class="nav-item @GetActiveCss("jobs")">
                <a href="jobs" @onclick='() => NavigateTo("jobs")'>
                    <svg class="nav-icon" viewBox="0 0 24 24">
                        <path d="M19 3h-4.18C14.4 1.84 13.3 1 12 1c-1.3 0-2.4.84-2.82 2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 0c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm2 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z" />
                    </svg>
                    Tarefas
                </a>
            </li>
            <li class="nav-item @GetActiveCss("destinations")">
                <a href="destinations" @onclick='() => NavigateTo("destinations")'>
                    <svg class="nav-icon" viewBox="0 0 24 24">
                        <path d="M20 13c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2H4c-1.1 0-2 .9-2 2v6c0 1.1.9 2 2 2h16zm-16-8h16v6H4V5zm16 14c1.1 0 2-.9 2-2v-6c0-1.1-.9-2-2-2H4c-1.1 0-2 .9-2 2v6c0 1.1.9 2 2 2h16zm-16-8h16v6H4v-6z" />
                    </svg>
                    Repositórios
                </a>
            </li>
            <li class="nav-item @GetActiveCss("restore")">
                <a href="restore" @onclick='() => NavigateTo("restore")'>
                    <svg class="nav-icon" viewBox="0 0 24 24">
                        <path d="M12 5V1L7 6l5 5V7c3.31 0 6 2.69 6 6 0 2.97-2.17 5.43-5 5.91v2.02c3.95-.49 7-3.85 7-7.93 0-4.42-3.58-8-8-8zm-6 8c0-1.65.67-3.15 1.76-4.24L6.34 7.34C4.9 8.79 4 10.79 4 13c0 4.08 3.05 7.44 7 7.93v-2.02c-2.83-.48-5-2.94-5-5.91z" />
                    </svg>
                    Recuperação
                </a>
            </li>
            <li class="nav-item @GetActiveCss("schedules")">
                <a href="schedules" @onclick='() => NavigateTo("schedules")'>
                    <svg class="nav-icon" viewBox="0 0 24 24">
                        <path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z" />
                    </svg>
                    Agendador
                </a>
            </li>
            <li class="nav-item @GetActiveCss("security")">
                <a href="security" @onclick='() => NavigateTo("security")'>
                    <svg class="nav-icon" viewBox="0 0 24 24">
                        <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z" />
                    </svg>
                    Segurança
                </a>
            </li>
        </ul>

        <div class="sidebar-footer">
            <div class="status-badge">
                <span class="dot"></span>
                <span>Serviço Rodando</span>
            </div>
            <div style="font-size: 11px; color: var(--text-muted);">
                Base: <span style="font-weight:600; color:var(--accent-color);">@_dbType</span>
            </div>
        </div>
    </aside>

    <!-- Main Content Area -->
    <main class="main-content">
        <header class="main-header">
            <h1 class="page-title">@_pageTitle</h1>
            <div class="header-actions">
                <button class="theme-toggle" @onclick="ToggleTheme" title="Alternar Tema">
                    @if (_theme == "dark")
                    {
                        <svg class="nav-icon" viewBox="0 0 24 24" style="color: #fbbf24;">
                            <path d="M12 7c-2.76 0-5 2.24-5 5s2.24 5 5 5 5-2.24 5-5-2.24-5-5-5zM2 13h2c.55 0 1-.45 1-1s-.45-1-1-1H2c-.55 0-1 .45-1 1s.45 1 1 1zm18 0h2c.55 0 1-.45 1-1s-.45-1-1-1h-2c-.55 0-1 .45-1 1s.45 1 1 1zM11 2v2c0 .55.45 1 1 1s1-.45 1-1V2c0-.55-.45-1-1-1s-1 .45-1 1zm0 18v2c0 .55.45 1 1 1s1-.45 1-1v-2c0-.55-.45-1-1-1s-1 .45-1 1zM5.99 4.58c-.39-.39-1.03-.39-1.41 0s-.39 1.03 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0s.39-1.03 0-1.41L5.99 4.58zm12.37 12.37c-.39-.39-1.03-.39-1.41 0s-.39 1.03 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0s.39-1.03 0-1.41l-1.06-1.06zm1.06-12.37c-.39.39-.39 1.03 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0s.39-1.03 0-1.41l-1.06-1.06c-.39-.39-1.03-.39-1.41 0zm-12.37 12.37c-.39.39-.39 1.03 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0s.39-1.03 0-1.41l-1.06-1.06c-.39-.39-1.03-.39-1.41 0z" fill="currentColor"/>
                        </svg>
                    }
                    else
                    {
                        <svg class="nav-icon" viewBox="0 0 24 24" style="color: #6b7280;">
                            <path d="M12.3 2a10 10 0 0 0-1.9 19.8 10 10 0 0 0 10.9-13.7c-1.3 1.4-3.2 2.2-5.3 2.2-4 0-7.3-3.2-7.3-7.3 0-2.2.9-4.2 2.3-5.5L12.3 2z" fill="currentColor"/>
                        </svg>
                    }
                </button>
                <div style="display: flex; flex-direction: column; text-align: right;">
                    <span style="font-size: 13px; font-weight: 600;">Administrador</span>
                    <span style="font-size: 11px; color: var(--text-secondary);">Active Directory</span>
                </div>
            </div>
        </header>

        <div class="content-wrapper fade-in">
            @Body
        </div>
    </main>
</div>

@code {
    private string _theme = "dark";
    private string _pageTitle = "Dashboard Geral";
    private string _dbType = "SQLite";

    protected override void OnInitialized()
    {
        NavigationService.OnNavigateRequested += HandleNavigate;
        
        // Fetch current active settings
        var settings = DbContext.AppSettings.FirstOrDefault();
        if (settings != null)
        {
            _theme = settings.Theme.ToLower();
            _dbType = settings.DatabaseType;
        }

        UpdatePageTitle(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        UpdatePageTitle(e.Location);
        StateHasChanged();
    }

    private void UpdatePageTitle(string uri)
    {
        var relative = NavigationManager.ToBaseRelativePath(uri);
        _pageTitle = relative switch
        {
            "" => "Dashboard Geral",
            "jobs" => "Gerenciamento de Backups (Jobs)",
            "destinations" => "Destinos de Armazenamento (Repositórios)",
            "restore" => "Console de Recuperação de Dados",
            "schedules" => "Políticas de Agendamento e Retenção",
            "security" => "Segurança & Conformidade (Active Directory)",
            _ => "BackupCR"
        };
    }

    private string GetActiveCss(string segment)
    {
        var relative = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        return relative == segment ? "active" : "";
    }

    private void NavigateTo(string path)
    {
        NavigationManager.NavigateTo(path);
    }

    private void HandleNavigate(string page)
    {
        InvokeAsync(() => {
            NavigationManager.NavigateTo(page);
            StateHasChanged();
        });
    }

    private void ToggleTheme()
    {
        _theme = _theme == "dark" ? "light" : "dark";
        
        var settings = DbContext.AppSettings.FirstOrDefault();
        if (settings != null)
        {
            settings.Theme = _theme == "dark" ? "Dark" : "Light";
            DbContext.SaveChanges();
        }
    }

    public void Dispose()
    {
        NavigationService.OnNavigateRequested -= HandleNavigate;
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
