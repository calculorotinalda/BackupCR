<Window x:Class="BackupCR.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:blazor="clr-namespace:Microsoft.AspNetCore.Components.WebView.Wpf;assembly=Microsoft.AspNetCore.Components.WebView.Wpf"
        xmlns:components="clr-namespace:BackupCR.Components"
        Title="BackupCR - Veeam Inspired Backup &amp; Replication"
        Height="768" Width="1180"
        MinHeight="680" MinWidth="1024"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/icons/icon.ico"
        Background="#0f1115">
    <Grid>
        <blazor:BlazorWebView x:Name="blazorWebView" HostPage="wwwroot/index.html">
            <blazor:BlazorWebView.RootComponents>
                <blazor:RootComponent Selector="#app" ComponentType="{x:Type components:App}" />
            </blazor:BlazorWebView.RootComponents>
        </blazor:BlazorWebView>
    </Grid>
</Window>
